# ─── Supabase ────────────────────────────────────────────────────────────────
# URL pública del proyecto Supabase
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon key — Settings → API → "anon public"
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Google Sheets OAuth 2.0 ─────────────────────────────────────────────────
# OAuth Client ID (público, va al browser)
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID

# ID de la hoja de cálculo de destino
VITE_GOOGLE_SHEET_ID=YOUR_GOOGLE_SHEET_ID

# ─── Google Sheets Client Secret (SOLO server-side / Edge Functions) ─────────
# SIN prefijo VITE_ — nunca se expone al browser
# Solo se usa en supabase/functions/
GOOGLE_SHEETS_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET

# ─── App ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME=SmartCart
VITE_APP_VERSION=0.1.0
NODE_ENV=development
